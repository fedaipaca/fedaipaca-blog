<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Basics</title>
  </head>
  <body class="min-h-dvh overflow-x-hidden font-sans antialiased bg-gray-100 pt-16">
    <!-- left right vertical borders, full screen height -->
    <div class="pointer-events-none fixed inset-0 z-50 flex justify-center">
      <div class="h-full w-full max-w-7xl border-r-[1px] border-l-[1px] border-gray-400"></div>
    </div>
    <!-- end of left right borders -->

    <nav class="fixed top-0 right-0 left-0 z-40 h-16 border-b-[1px] border-gray-400 bg-gray-100">
      <div class="mx-auto flex h-full max-w-7xl justify-between">
        <div class="flex items-stretch">
          <a href="/" class="flex items-center px-10 text-lg font-medium font-mono hover:underline">fedaipaca.</a>
        </div>
        <div class="flex items-stretch">
          <a href="/" class="flex items-center px-8 hover:bg-stone-200">Home</a>
          <a href="/" class="flex items-center px-8 hover:bg-stone-200">Blog</a>
          <a href="/" class="flex items-center px-8 hover:bg-stone-200">About</a>
          <a href="/" class="flex items-center px-10 border-l border-gray-400 hover:bg-stone-200">Contact</a>
        </div>
      </div>
    </nav>

    <header class="max-w-7xl mx-auto">
      <section class="h-[32rem] px-10 flex items-center">
        <h1 class="text-9xl tracking-tight">Code feature</h1>
      </section>
    </header>

    <main class="">
      <div class="max-w-7xl mx-auto border-t border-gray-400 flex items-stretch">
        <div class="border-r-[1px] border-gray-400 flex-1">
          <div class="divide-y-[1px] divide-gray-400">
            {
              posts.map((post, i) => (
                <a href={post.url} class="flex p-10 group hover:bg-white">
                  <div class="w-48 h-32 flex-shrink-0" style={`background-color: hsl(${i * 24}, 70%, 80%)`} />
                  <div class="flex-1 ml-10 flex flex-col justify-between space-y-2">
                    <div>
                      <h2 class="text-3xl font-semibold mb-1  group-hover:underline">{post.title}</h2>
                      <p class="text-gray-600 text-sm mb-2">{post.description}</p>
                    </div>
                    <div class="flex items-center justify-between text-xs text-gray-500 font-mono tracking-tighter">
                      <span>
                        {new Date(post.publishDate).toLocaleDateString("en-US", {
                          year: "numeric",
                          month: "long",
                          day: "numeric",
                        })}
                      </span>
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
        <div class="w-96 p-10 sticky top-16 self-start">
