---
import Navigation from "../components/Navigation.astro";
import LayoutBorders from "../components/LayoutBorders.astro";
import "../styles/global.css";
import Footer from "../components/Footer.astro";

const { title } = Astro.props;
const pageTitle = title ? `${title} | fedaipaca.` : "fedaipaca.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden font-sans antialiased bg-gray-100 pt-16">
    <LayoutBorders />
    <Navigation />

    <!-- Optional hero slot (e.g. large header/hero only present on some pages) -->
    <slot name="hero" />

    <!-- Page content is wrapped in a single main container for consistent width and SEO semantics -->
    <main class="max-w-7xl mx-auto flex-1">
      <slot />
    </main>

    <div class="w-full border-t border-gray-400">
      <div class="max-w-7xl mx-auto p-8">
        <Footer />
      </div>
    </div>
  </body>
</html>
